# Runtime Environment
# NODE_ENV="development"
# LOG_LEVEL="info"
# LOG_TO_CONSOLE=true

# GitHub Personal Access Token with 'repo' scope
GH_TOKEN=

# Fallback GitHub PAT for 403 permission errors
# GH_PAT_TOKEN=

# Fork repository configuration
# REPO_FORK_OWNER="nivaldofarias"
# REPO_FORK_NAME="pt-br.react.dev"

# Upstream repository configuration
# Upstream owner; use your GitHub username while testing so PRs target your fork
# REPO_UPSTREAM_OWNER="reactjs"
# REPO_UPSTREAM_NAME="pt-br.react.dev"

# OpenAI-compatible API key
LLM_API_KEY=

# LLM API endpoint and model configuration
# LLM_MODEL="google/gemini-2.0-flash-exp:free"
# LLM_API_BASE_URL="https://openrouter.ai/api/v1"
# OPENAI_PROJECT_ID=
# MAX_TOKENS=8192

# OpenRouter activity tracking headers
# HEADER_APP_URL="https://github.com/NivaldoFarias/translate-react"
# HEADER_APP_TITLE="translate-react v0.1.23"

# Translation language configuration (SOURCE_LANGUAGE defaults to en; omit unless non-English)
# TARGET_LANGUAGE="pt-br"

# Processing batch size
# BATCH_SIZE=10
