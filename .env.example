# Runtime Environment
# NODE_ENV="development"
# LOG_LEVEL="info"
# LOG_TO_CONSOLE=true

# GitHub Personal Access Token with 'repo' scope
GH_TOKEN=

# Fallback GitHub PAT for 403 permission errors
# GH_PAT_TOKEN=

# Fork repository configuration
# REPO_FORK_OWNER="nivaldofarias"
# REPO_FORK_NAME="pt-br.react.dev"

# Upstream repository configuration
# REPO_UPSTREAM_OWNER="reactjs"
# REPO_UPSTREAM_NAME="pt-br.react.dev"

# OpenAI-compatible API key
LLM_API_KEY=

# Optional for `bun run smoke:llm-workflow`: repo-relative markdown for a larger smoke run
# LLM_WORKFLOW_SMOKE_MARKDOWN=tests/fixtures/react-labs-view-transitions-activity-and-more.md

# LLM API endpoint and model configuration
# LLM_MODEL="google/gemini-2.0-flash-exp:free"
# LLM_API_BASE_URL="https://openrouter.ai/api/v1"
# OPENAI_PROJECT_ID=
# MAX_TOKENS=8192

# MASK_VERBATIM_LARGE_FENCES=false
# MASK_VERBATIM_LARGE_FENCES_MIN_TOKENS=120

# Optional; default HEADER_* from package.json (homepage, name, version)
# HEADER_APP_URL=
# HEADER_APP_TITLE=

# TARGET_LANGUAGE="pt-br"

# BATCH_SIZE=10
