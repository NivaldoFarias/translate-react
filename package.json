{
	"name": "translate-react",
	"version": "0.2.10",
	"contributors": [
		{
			"name": "Nivaldo Farias",
			"url": "https://github.com/NivaldoFarias"
		}
	],
	"license": "MIT",
	"homepage": "https://github.com/NivaldoFarias/translate-react",
	"description": "Translate react.dev locale repos when upstream changes",
	"type": "module",
	"engines": {
		"bun": ">=1.3.0"
	},
	"scripts": {
		"start": "bun src/app/main.ts",
		"dev": "bun --watch src/app/main.ts",
		"build": "bun src/app/build.ts",
		"lint": "eslint . --cache",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"type-check": "tsc",
		"test": "bun test",
		"ci:poll-upstream": "bun src/ci/actions/poll-upstream.ts",
		"ci:resolve-matrix": "bun src/ci/actions/resolve-matrix.ts",
		"ci:verify-changelog": "bun src/ci/actions/verify-changelog.ts",
		"ci:smoke": "bun src/ci/actions/smoke.ts",
		"ci:changelog-notes": "bun src/ci/actions/changelog-notes.ts",
		"release:prepare": "bun src/ci/actions/prepare-release.ts",
		"test:watch": "bun test --watch",
		"test:coverage": "bun test --coverage"
	},
	"dependencies": {
		"@langchain/textsplitters": "^1.0.1",
		"@octokit/request-error": "^7.0.1",
		"@octokit/rest": "^22.0.1",
		"citty": "^0.2.2",
		"cld": "^2.10.1",
		"http-status-codes": "^2.3.0",
		"js-tiktoken": "^1.0.21",
		"openai": "^6.17.0",
		"p-queue": "^9.1.0",
		"p-retry": "^8.0.0",
		"pino": "^10.3.0",
		"pretty-bytes": "^7.1.0",
		"remark-gfm": "^4.0.1",
		"remark-mdx": "^3.1.1",
		"remark-parse": "^11.0.0",
		"typescript": "^6.0.3",
		"unified": "^11.0.5",
		"unist-util-position": "^5.0.0",
		"unist-util-visit-parents": "^6.0.2",
		"yaml": "^2.9.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@ianvs/prettier-plugin-sort-imports": "^4.4.1",
		"@mdx-js/mdx": "^3.1.1",
		"@total-typescript/ts-reset": "^0.6.1",
		"@types/bun": "^1.3.8",
		"@types/eslint": "^9.6.1",
		"@types/mdast": "^4.0.4",
		"@types/node": "^26.1.0",
		"@typescript-eslint/eslint-plugin": "^8.60.1",
		"@typescript-eslint/parser": "^8.60.1",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.0.1",
		"eslint-plugin-jsdoc": "^63.0.1",
		"globals": "^17.2.0",
		"jiti": "^2.6.1",
		"mdast-util-to-markdown": "^2.1.2",
		"pino-pretty": "^13.1.2",
		"prettier": "^3.8.3",
		"type-fest": "^5.4.2",
		"typescript-eslint": "^8.60.1",
		"unist-util-visit": "^5.1.0"
	}
}
